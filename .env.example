# ═══════════════════════════════════════════════════
#          KanhaMusic — Configuration File
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in all the values.
# Or set these as environment variables / Replit Secrets.

# ── Telegram API Credentials ────────────────────────
# Get from https://my.telegram.org
API_ID=
API_HASH=

# ── Bot Token ───────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=

# ── Assistant String Session ────────────────────────
# Generate using: python generate_session.py
# Needed for joining voice chats
STRING_SESSION=

# ── Owner Info ──────────────────────────────────────
OWNER_ID=
OWNER_USERNAME=

# ── Log Group ───────────────────────────────────────
# Group/Channel ID where bot sends startup logs
LOG_GROUP_ID=

# ── Support Links ───────────────────────────────────
SUPPORT_GROUP=https://t.me/KanhaMusicSupport
SUPPORT_CHANNEL=https://t.me/KanhaMusicUpdates

# ── Bot Branding ────────────────────────────────────
BOT_NAME=KanhaMusic
BOT_USERNAME=KanhaMusicBot

# ── Spotify (Optional) ──────────────────────────────
# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Limits ──────────────────────────────────────────
# Max song duration for streaming (in minutes)
DURATION_LIMIT=180

# Max song duration for downloading (in minutes)
SONG_DOWNLOAD_DURATION_LIMIT=30

# Max tracks to fetch from playlists
PLAYLIST_FETCH_LIMIT=25

# ── Thumbnail ───────────────────────────────────────
YOUTUBE_IMG_URL=https://h.uguu.se/PEdxUfYu.jpg
STREAM_IMG_URL=https://h.uguu.se/PEdxUfYu.jpg
